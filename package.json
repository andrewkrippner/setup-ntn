{
  "name": "setup-ntn",
  "version": "1.0.0",
  "description": "GitHub Action that installs the ntn (Notion) CLI and configures auth",
  "main": "dist/setup/index.js",
  "scripts": {
    "build": "ncc build -o dist/setup src/setup-ntn.ts",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "pre-checkin": "npm run format && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewkrippner/setup-ntn.git"
  },
  "keywords": [
    "actions",
    "notion",
    "ntn",
    "setup",
    "ci",
    "cd",
    "workers"
  ],
  "author": "Andrew Krippner",
  "license": "MIT",
  "devDependencies": {
    "@types/command-exists": "^1.2.3",
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/io": "^1.1.3",
    "command-exists": "^1.2.9"
  }
}
