{
  "name": "setup-ntn",
  "version": "1.0.0",
  "description": "GitHub Action that installs the ntn (Notion) CLI and configures auth",
  "main": "dist/setup/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/setup-ntn.ts --bundle --platform=node --target=node24 --format=esm --outfile=dist/setup/index.js --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\"",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "pre-checkin": "npm run format && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewkrippner/setup-ntn.git"
  },
  "keywords": [
    "actions",
    "notion",
    "ntn",
    "setup",
    "ci",
    "cd",
    "workers"
  ],
  "author": "Andrew Krippner",
  "license": "MIT",
  "devDependencies": {
    "@types/command-exists": "^1.2.3",
    "@types/node": "^24.12.4",
    "esbuild": "^0.28.0",
    "prettier": "^3.2.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "command-exists": "^1.2.9"
  }
}
